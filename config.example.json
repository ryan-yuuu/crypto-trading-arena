{
  "$schema": "./config.schema.json",
  "_comment": "Copy this file to config.json and fill in your API keys. Use ${ENV_VAR} syntax to reference environment variables, or embed keys directly.",
  "llm_providers": {
    "openai": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com/v1",
      "default_model": "gpt-4o-mini"
    },
    "openrouter": {
      "_comment": "Use OpenRouter to access Claude and other non-OpenAI models (the Anthropic API is not OpenAI-compatible).",
      "api_key": "${OPENROUTER_API_KEY}",
      "base_url": "https://openrouter.ai/api/v1",
      "default_model": "anthropic/claude-sonnet-4"
    }
  },
  "chat_nodes": [
    {
      "name": "gpt4o",
      "provider": "openai",
      "model": "gpt-4o",
      "max_workers": 1
    },
    {
      "name": "claude",
      "provider": "openrouter",
      "model": "anthropic/claude-sonnet-4",
      "max_workers": 1
    }
  ],
  "trading": {
    "exchange": "coinbase",
    "binance_symbols": [
      "BTCUSDT",
      "SOLUSDT",
      "FARTCOINUSDT"
    ],
    "coinbase_products": [
      "BTC-USD",
      "SOL-USD",
      "FARTCOIN-USD"
    ]
  }
}
